generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Home {
  id      Int    @id @default(autoincrement())
  key     String @unique
  content String
}

model Faq {
  id       Int    @id @default(autoincrement())
  key      String @unique
  question String
  answer   String
}

model Operators {
  id      Int    @id @default(autoincrement())
  key     String @unique
  name    String
  idName  String @unique
  imageID String @unique
  hover   String
}

model Header {
  id      Int    @id @default(autoincrement())
  key     String @unique
  content String
}

model Footer {
  id      Int    @id @default(autoincrement())
  key     String @unique
  content String
}

model Packets {
  id             Int    @id @default(autoincrement())
  key            String
  packet_title   String
  packet_content String
  kupur          String
  heryone_dk     Int
  yd_dk          Int
  heryone_sms    Int
  heryone_int    Int
  price          Int
}

